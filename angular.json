{
	"$schema": "./node_modules/@angular/cli/lib/config/schema.json",
	"version": 1,
	"newProjectRoot": "projects",
	"projects": {
		"shell": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": {
					"style": "scss"
				}
			},
			"root": "projects/shell",
			"sourceRoot": "projects/shell/src",
			"prefix": "app",
			"architect": {
			"build": {
			"builder": "ngx-build-plus:browser",
			"options": {
			"outputPath": "dist/shell",
			"index": "projects/shell/src/index.html",
			"main": "projects/shell/src/main.ts",
			"polyfills": ["zone.js"],
			"tsConfig": "projects/shell/tsconfig.app.json",
			"inlineStyleLanguage": "scss",
			"assets": ["projects/shell/src/assets",
					   "projects/shell/src/assets/manifest.json" ],
			"styles": ["projects/shell/src/styles.scss"],
			"scripts": [],
			"extraWebpackConfig": "projects/shell/webpack.config.js"
			},
			"configurations": {
			"production": {
				"optimization": true,
				"outputHashing": "all",
				"sourceMap": false,
				"namedChunks": false,
				"aot": true,
				"extractLicenses": true,
				"vendorChunk": false,
				"buildOptimizer": true,
				"budgets": [
				{
					"type": "initial",
					"maximumWarning": "500kb",
					"maximumError": "1mb"
				}
				],
				"extraWebpackConfig": "projects/shell/webpack.config.js"
			},
			"development": {
				"optimization": false,
				"sourceMap": true,
        "namedChunks": true,
        "fileReplacements": [
          {
            "replace": "projects/shell/src/environments/environment.ts",
            "with": "projects/shell/src/environments/environment.development.ts"
          }
        ]
			}
			},
			"defaultConfiguration": "production"
		},
		"serve": {
			"builder": "ngx-build-plus:dev-server",
			"options": {
			"port": 4200,
			"publicHost": "http://localhost:4200",
			"extraWebpackConfig": "projects/shell/webpack.config.js"
			},
			"configurations": {
			"production": {
				"buildTarget": "shell:build:production"
			},
			"development": {
				"buildTarget": "shell:build:development"
			}
			},
			"defaultConfiguration": "development"
		}
		}
		},
		"profile-mfe": {
			"projectType": "application",
			"schematics": {
				"@schematics/angular:component": {
					"style": "scss"
				}
			},
			"root": "projects/profile-mfe",
			"sourceRoot": "projects/profile-mfe/src",
			"prefix": "app",
			"architect": {
			"build": {
				"builder": "ngx-build-plus:browser",
				"options": {
				"outputPath": "dist/profile-mfe",
				"index": "projects/profile-mfe/src/index.html",
				"main": "projects/profile-mfe/src/main.ts",
				"polyfills": ["zone.js"],
				"tsConfig": "projects/profile-mfe/tsconfig.app.json",
				"inlineStyleLanguage": "scss",
				"assets": ["projects/profile-mfe/src/assets"],
				"styles": ["projects/profile-mfe/src/styles.scss"],
				"scripts": [],
				"extraWebpackConfig": "projects/profile-mfe/webpack.config.js"
				},
				"configurations": {
				"production": {
					"optimization": true,
					"outputHashing": "all",
					"sourceMap": false,
					"namedChunks": false,
					"aot": true,
					"extractLicenses": true,
					"vendorChunk": false,
					"buildOptimizer": true,
					"budgets": [
					{
						"type": "initial",
						"maximumWarning": "500kb",
						"maximumError": "1mb"
					}
					],
					"extraWebpackConfig": "projects/profile-mfe/webpack.config.js"
				},
				"development": {
					"optimization": false,
					"sourceMap": true,
          "namedChunks": true,
          "fileReplacements": [
            {
              "replace": "projects/profile-mfe/src/environments/environment.ts",
              "with": "projects/profile-mfe/src/environments/environment.development.ts"
            }
          ]
				}
				},
				"defaultConfiguration": "production"
			},
			"serve": {
				"builder": "ngx-build-plus:dev-server",
				"options": {
				"port": 4201,
				"publicHost": "http://localhost:4201",
				"extraWebpackConfig": "projects/profile-mfe/webpack.config.js"
				},
				"configurations": {
				"production": {
					"buildTarget": "profile-mfe:build:production"
				},
				"development": {
					"buildTarget": "profile-mfe:build:development"
				}
				},
				"defaultConfiguration": "development"
			}
			}


          },
          "shared-assets": {
            "projectType": "library",
            "root": "projects/shared-assets",
            "sourceRoot": "projects/shared-assets/src",
            "prefix": "lib",
            "architect": {
              "build": {
                "builder": "@angular-devkit/build-angular:ng-packagr",
                "options": {
                  "project": "projects/shared-assets/ng-package.json"
                },
                "configurations": {
                  "production": {
                    "tsConfig": "projects/shared-assets/tsconfig.lib.prod.json"
                  },
                  "development": {
                    "tsConfig": "projects/shared-assets/tsconfig.lib.json"
                  }
                },
                "defaultConfiguration": "production"
              },
              "test": {
                "builder": "@angular-devkit/build-angular:karma",
                "options": {
                  "tsConfig": "projects/shared-assets/tsconfig.spec.json",
                  "polyfills": [
                    "zone.js",
                    "zone.js/testing"
                  ]
                }
              }
            }
          }
				},
				"cli": {
					"analytics": false
				}
			}